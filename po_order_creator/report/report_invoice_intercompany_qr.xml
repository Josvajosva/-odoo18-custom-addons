<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Intercompany SO invoices: QR encodes sale_order_id|invoice_id next to address -->
    <template id="report_invoice_document_intercompany_qr" inherit_id="account.report_invoice_document">
        <xpath expr="//div[hasclass('row')]/t[1]" position="before">
            <t t-if="o.is_intercompany_so_invoice">
                <t t-set="so_ids" t-value="o._get_intercompany_po_ids()"/>
                <t t-set="qr_value" t-value="'%s|%s' % (so_ids, o.id)"/>
                <div class="col-auto ms-auto" style="text-align: right; position: absolute; top: 30px; right: 30px;">
                    <img t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=120&amp;height=120' % qr_value"
                         alt="QR"
                         style="width: 120px; height: 120px; display: block;"/>
<!--                    <small style="font-size: 0.75rem;" t-out="qr_value"/>-->
                </div>
            </t>
        </xpath>
    </template>
</odoo>