<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_request_confirm_wizard" model="ir.ui.view">
        <field name="name">purchase.request.confirm.wizard.form</field>
        <field name="model">purchase.request.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm To Create Purchase Request">
                <div class="o_row">
                    <label for="dummy_field" string="Do you want to create a Purchase Request?" class="o_form_label"/>
                    <field name="dummy_field" invisible="1" readonly="1" class="o_field_widget"/>
                </div>
                <footer>
                    <button string="Yes" type="object" name="action_confirm_pr" class="btn-primary"/>
                    <button string="Cancel" type="object" name="action_cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_purchase_request_confirm_wizard" model="ir.actions.act_window">
        <field name="name">Purchase Request Confirmation</field>
        <field name="res_model">purchase.request.confirm.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_purchase_request_confirm_wizard"/>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_purchase_request_confirm_wizard"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>
