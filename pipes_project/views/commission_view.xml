<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==========================
         Menu Items
    =========================== -->
    <menuitem id="menu_invoice_config" name="Commission Configuration" parent="account.menu_finance_configuration"/>

    <!-- ==========================
         Commission Rules Views
    =========================== -->
    <record id="view_commission_rule_tree" model="ir.ui.view">
        <field name="name">commission.rule.tree</field>
        <field name="model">invoice.commission.rule</field>
        <field name="arch" type="xml">
            <list string="Commission Rules">
                <field name="name"/>
                <field name="base_field"/>
                <field name="percentage"/>
                <field name="condition_field"/>
                <field name="min_days"/>
                <field name="max_days"/>
                <field name="release_penalty_on"/>
                <field name="system_type"/>
                        <field name="commission_per_catg"/>
            </list>
        </field>
    </record>

    <record id="view_commission_rule_form" model="ir.ui.view">
        <field name="name">commission.rule.form</field>
        <field name="model">invoice.commission.rule</field>
        <field name="arch" type="xml">
            <form string="Commission Rule">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="base_field"/>
                        <field name="percentage"/>
                        <field name="condition_field"/>
                        <field name="min_days"/>
                        <field name="max_days"/>
                        <field name="release_penalty_on"/>
                        <field name="system_type"/>
                        <field name="commission_per_catg"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_commission_rules" model="ir.actions.act_window">
        <field name="name">Commission Rules</field>
        <field name="res_model">invoice.commission.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="submenu_commission_rules" name="Commission Rules"
              parent="menu_invoice_config" action="action_commission_rules"/>

    <!-- ==========================
         Deduction Rules Views
    =========================== -->
    <record id="view_deduction_rule_tree" model="ir.ui.view">
        <field name="name">deduction.rule.tree</field>
        <field name="model">invoice.deduction.rule</field>
        <field name="arch" type="xml">
            <list string="Deduction Rules">
                <field name="name"/>
                <field name="base_field"/>
                <field name="percentage"/>
                <field name="condition_field"/>
                <field name="min_days"/>
                <field name="max_days"/>
                <field name="system_type"/>
                        <field name="commission_per_catg"/>
            </list>
        </field>
    </record>

    <record id="view_deduction_rule_form" model="ir.ui.view">
        <field name="name">deduction.rule.form</field>
        <field name="model">invoice.deduction.rule</field>
        <field name="arch" type="xml">
            <form string="Deduction Rule">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="base_field"/>
                        <field name="percentage"/>
                        <field name="condition_field"/>
                        <field name="min_days"/>
                        <field name="max_days"/>
                        <field name="system_type"/>
                        <field name="commission_per_catg"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_deduction_rules" model="ir.actions.act_window">
        <field name="name">Deduction Rules</field>
        <field name="res_model">invoice.deduction.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="submenu_deduction_rules" name="Deduction Rules"
              parent="menu_invoice_config" action="action_deduction_rules"/>

    <!-- ==========================
         Commission/Deduction History Views
    =========================== -->
    <record id="view_commission_history_tree" model="ir.ui.view">
        <field name="name">commission.history.tree</field>
        <field name="model">invoice.commission.history</field>
        <field name="arch" type="xml">
            <list string="Commission/Deduction History">
                <field name="invoice_id"/>
                <field name="rule_percentage"/>
                <field name="rule_max_days"/>
                <field name="rule_type"/>
                <field name="condition_field"/>
                <field name="commission"/>
                <field name="deduction"/>
                <field name="log_date"/>
                <field name="system_type"/>
                        <field name="commission_per_catg"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="view_commission_history_form" model="ir.ui.view">
        <field name="name">commission.history.form</field>
        <field name="model">invoice.commission.history</field>
        <field name="arch" type="xml">
            <form string="Commission/Deduction History">
                <sheet>
                    <group>
                        <field name="invoice_id"/>
                        <field name="rule_percentage"/>
                        <field name="rule_max_days"/>
                        <field name="rule_type"/>
                        <field name="condition_field"/>
                        <field name="commission"/>
                        <field name="deduction"/>
                        <field name="log_date"/>
                        <field name="system_type"/>
                        <field name="commission_per_catg"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_commission_history" model="ir.actions.act_window">
        <field name="name">Commission/Deduction History</field>
        <field name="res_model">invoice.commission.history</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="submenu_commission_history" name="Commission/Deduction History"
              parent="menu_invoice_config" action="action_commission_history"/>
</odoo>

