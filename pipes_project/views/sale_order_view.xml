<odoo>
    <record id="view_order_form_inherit_service_stage" model="ir.ui.view">
        <field name="name">sale.order.form.service.stage</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header/field[@name='state']" position="replace">
                <field name="state" widget="statusbar"
                       options="{'clickable': True}"
                       statusbar_visible="draft,sent,sale,done,cancel,pre_inspection"/>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_mark_preinspection_approved"
                        string=" Pre Inspection "
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft' or approve_active != False"/>

                <button name="action_mark_approved"
                        string=" Pre Inspection Approved"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'pre_inspection'"/>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="dealer_id"/>
                <field name="application_id" invisible="0"/>
                <field name="farmer_type_crm" invisible="0"/>
                <field name="government_contribution" invisible="farmer_type_crm != '70_percent'"/>
                <field name="farmer_contribution" invisible="farmer_type_crm != '70_percent'"/>
            </xpath>


            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="approve_active" invisible="1"/>
                <field name="sales_area"/>
                <field name="sales_manager"/>
                <field name="pre_approve_active" invisible="1"/>
                <field name="farmer_image_filename" invisible="1"/>
                <field name="farmer_dd_image" widget="binary" filename="farmer_image_filename"
                       readonly="approve_active != False"
                       invisible="pre_approve_active != True or farmer_type_crm != '70_percent'"/>
                <field name="payment_image_filename" invisible="1"/>
                <field name="payment_image" widget="binary" filename="payment_image_filename"
                       readonly="approve_active != False"
                       invisible="pre_approve_active != True"/>
                <field name="farmer_Acceptance_image_filename" invisible="1"/>

                <field name="farmer_Acceptance_image" widget="binary" filename="farmer_Acceptance_image_filename"
                       readonly="approve_active != False"
                       invisible="pre_approve_active != True"/>

            </xpath>

            <xpath expr="//notebook/page[@name='customer_signature']" position="after">
                <page string="Farmer Information " name="farmer_assignment_tab">
                    <group>
                        <group>
                            <field name="sale_latitude" invisible="0"/>
                            <field name="sale_longitude" invisible="0"/>
                            <field name="survey_number" invisible="0"/>
                            <field name="sub_division_no" invisible="0"/>
                            <field name="crop_name" invisible="0"/>
                            <field name="pro_rata_spacing" invisible="0"/>
                            <field name="applied_area" invisible="0"/>
                            <field name="block" invisible="0"/>
                        </group>
                        <group>
                            <field name="department" invisible="0"/>
                            <field name="scheme" invisible="0"/>
                            <field name="mi_type" invisible="0"/>
                            <field name="mi_area" invisible="0"/>
                            <field name="total_area" invisible="0"/>
                            <field name="sale_latitude" invisible="0"/>
                            <field name="spacing" invisible="0"/>
                        </group>
                    </group>
                </page>


            </xpath>


        </field>
    </record>
</odoo>