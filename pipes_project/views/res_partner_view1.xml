<?xml version="1.0"?>
<odoo>


    <record id="view_partners_pipes" model="ir.ui.view">
        <field name="name">view.res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field eval="1" name="priority"/>
        <field name="arch" type="xml">
            <!--<xpath expr="//field[@name='vat']" position="after">
                <field name="application_id"/>
                <field name="village"/>
                <field name="caste"/>
                <field name="gender"/>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="father_name"/>
                <field name="district"/>
                <field name="department"/>
            </xpath>-->
            <xpath expr="//field[@name='ref']" position="after">
                <field name="commission_per_catg"/>
            </xpath>
            <xpath expr="//field[@name='vat']" position="after">
                <field name="region"/>
            </xpath>
            <xpath expr="//notebook/page/group/group/field[@name='user_id']" position="after">
                <field name="staff_name"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_employee_form_inherit_region" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.region</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/notebook/page/div/div/group/field[@name='parent_id']" position="after">
                <field name="region"/>
            </xpath>
        </field>
    </record>

</odoo>
