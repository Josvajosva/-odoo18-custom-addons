<odoo>
    <record id="view_inventory_reverse_adjustment_form" model="ir.ui.view">
        <field name="name">inventory.reverse.adjustment.form</field>
        <field name="model">inventory.reverse.adjustment</field>
        <field name="arch" type="xml">
            <form string="Inventory Reverse Adjustment">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="Are you sure you want to confirm this Reverse Adjustment?"/>
                    <button name="action_view_moves" type="object" string="View Moves"
                            class="btn-secondary"
                            invisible="state != 'confirm'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="creation_date"/>
                        <field name="product_id" options="{'no_create': True}"/>
                        <field name="qty"/>
                        <field name="user_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_inventory_reverse_adjustment_tree" model="ir.ui.view">
        <field name="name">inventory.reverse.adjustment.tree</field>
        <field name="model">inventory.reverse.adjustment</field>
        <field name="arch" type="xml">
            <list string="Inventory Reverse Adjustment">
                <field name="name"/>
                <field name="creation_date"/>
                <field name="product_id"/>
                <field name="qty"/>
                <field name="user_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_inventory_reverse_adjustment" model="ir.actions.act_window">
        <field name="name">Inventory Reverse Adjustment</field>
        <field name="res_model">inventory.reverse.adjustment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_inventory_reverse_adjustment"
              name="Inventory Reverse Adjustment"
              parent="stock.menu_stock_adjustments"
              action="action_inventory_reverse_adjustment"
             />
</odoo>
