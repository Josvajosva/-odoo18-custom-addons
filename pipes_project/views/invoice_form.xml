<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_account_pipes_tree" model="ir.ui.view">
        <field name="name">account.move.tree.debit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">

            <header position="inside">
                <button name="action_sync_invoice_date"
                        string="Sync Invoice Date"
                        type="object"
                        class="oe_highlight"
                        confirm="Are you sure you want to sync all invoices' dates with their E-Way Bill dates?"/>
            </header>
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="application_id" />
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="before">
                <field name="dealer_id" string="Dealer"/>
                <field name="area_manager_id" string="Area Manager"/>
                <field name="work_status" string="Current Status"/>
            </xpath>
            <!-- <xpath expr="//field[@name='invoice_date_due']" position="replace"/> -->
            <!-- <xpath expr="//field[@name='activity_ids']" position="replace"/> -->
        </field>
    </record>
    
    <record id="view_move_account_pipes" model="ir.ui.view">
        <field name="name">account.move.form.debit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="dealer_id" domain="[('category_id.name', 'ilike', 'Dealer')]"/>
                <field name="area_manager_id" />
                <field name="invoice_farmer_type_crm" readonly="1"/>
                <field name="work_status"/>
                <field name="work_date"/>
                <field name="system_type"/>
                <!-- <field name="utr_number" invisible="work_status != 'fund_credited' "/>
                <field name="fund_credit_date" invisible="work_status != 'fund_credited' "/>
                <field name="fund_credit" invisible="work_status != 'fund_credited' "/> -->
                <field name="utr_number"/>
                <field name="fund_credit_date"/>
                <field name="fund_credit"/>
                
                
                <field name="farmer_dd_image" filename="farmer_image_filename"/>
                <field name="farmer_image_filename" readonly="1" invisible="1"/>
                <field name="payment_image" filename="payment_image_filename"/>
                <field name="payment_image_filename" readonly="1" invisible="1"/>
                <field name="farmer_acceptance_image" filename="farmer_acceptance_image_filename"/>
                <field name="farmer_acceptance_image_filename" readonly="1" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='delivery_date']" position="after">
                <field name="creation_date" readonly="1"/>
                <field name="application_id"/>
                <field name="eway_date" invisible="state != 'posted' "/>
                <field name="eway_number" invisible="state != 'posted' "/>
                <!-- <field name="work_completion_approved_date" invisible="work_status not in ('work_completion_approved', 'fund_release_recommended_block', 'fund_release_recommended_district', 'rectification_approved_block', 'rectification_reverted_block', 'fund_release_approved_agri', 'fund_release_approved_horti', 'utr_skipped', 'joint_verification_completed', 'fund_release_proceeding_completed', 'fund_credited', 'Fund Credited (UTR Updated)')"/> -->
                <field name="work_completion_approved_date"/>
                <field name="first_fund_utr_skipped_date" />
                <field name="first_fund"/>
                <!-- <field name="joint_verification_completed_date" invisible="work_status not in ('joint_verification_completed', 'fund_release_proceeding_completed', 'fund_credited', 'Fund Credited (UTR Updated)')"/> -->
                <field name="joint_verification_completed_date"/>
                <field name="government_contribution" invisible="0"/>
                <field name="farmer_contribution" invisible="0"/>
                <field name="zoho_invoice_no"/>

            </xpath>
            
            <xpath expr="//notebook/page[@name='other_info']" position="after">
                <page string="Farmer Information " name="farmer_assignment_tab">
                    <group>
                        <group>
                            <field name="sale_latitude" invisible="0"/>
                            <field name="sale_longitude" invisible="0"/>
                            <field name="survey_number" invisible="0"/>
                            <field name="sub_division_no" invisible="0"/>
                            <field name="crop_name" invisible="0"/>
                            <field name="pro_rata_spacing" invisible="0"/>
                            <field name="applied_area" invisible="0"/>
                            <field name="block" invisible="0"/>
                        </group>
                        <group>
                            <field name="department" invisible="0"/>
                            <field name="scheme" invisible="0"/>
                            <field name="mi_type" invisible="0"/>
                            <field name="mi_area" invisible="0"/>
                            <field name="total_area" invisible="0"/>
                            <field name="sale_latitude" invisible="0"/>
                            <field name="spacing" invisible="0"/>
                        </group>
                    </group>
                </page>
                <page string="Commission and Deduction " name="commissio_deduction">
                    <group>
                        <group>
<!--                            <field name="issued_work_order_date" invisible="0"/>-->
                            <field name="commission" readonly="1"/>
                            <field name="deduction" readonly="1"/>
                            <field name="commission_payable" readonly="1"/>
                            <field name="commission_notes" readonly="1" widget="text"/>
                        </group>
                        <group string="Fund UTR Commissions">
                            <field name="first_fund_utr_commission"/>
                            <field name="second_fund_utr_commission"/>
                        </group>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>

    <record id="view_move_filter_inherit_appid" model="ir.ui.view">
        <field name="name">account.move.search.inherit.appid</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="application_id" string="App ID"/>
            </xpath>
        </field>
    </record>

</odoo>
