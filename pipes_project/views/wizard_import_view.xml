<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="wizard_import_crm" model="ir.ui.view">
            <field name="name">wizard.wizard.import.crm.form</field>
            <field name="model">import.crm.data</field>
            <field name="arch" type="xml">
                <form string="Import CRM Opportunities">
                    <group>
                        <field name="import_option" widget="radio"/>
                    </group>

                    <group>
                        <field name="file_select" filename="name" string="Select CSV/Excel File"/>
                    </group>
                    
                    <footer>
                        <button string="Import Opportunities" name="import_file" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="bi_act_crm_import" model="ir.actions.act_window">
            <field name="name">Import CRM Opportunities</field>
            <field name="res_model">import.crm.data</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="wizard_import_crm"/>
            <field name="target">new</field>
        </record>

        <menuitem
            id="menu_crm_import"
            action="bi_act_crm_import"
            name="Import CRM Opportunities"
            parent="crm.crm_menu_root"
            sequence="20"/>

        <record id="wizard_import_invoice" model="ir.ui.view">
            <field name="name">wizard.import.invoice.form</field>
            <field name="model">import.invoice.data</field>
            <field name="arch" type="xml">
                <form string="Import Invoices">
                    <group>
                        <field name="import_option" widget="radio"/>
                    </group>

                    <group>
                        <field name="file_select" filename="name" string="Select CSV/Excel File"/>
                    </group>
                    
                    <footer>
                        <button string="Import Invoices" name="import_file" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="act_invoice_import" model="ir.actions.act_window">
            <field name="name">Import Invoices</field>
            <field name="res_model">import.invoice.data</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="wizard_import_invoice"/>
            <field name="target">new</field>
        </record>

        <menuitem
            id="menu_invoice_import"
            action="act_invoice_import"
            name="Import Invoices"
            parent="account.menu_finance_receivables"
            sequence="30"/>
    </data>
</odoo>
