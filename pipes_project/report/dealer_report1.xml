                                            <span t-esc="'{:,.2f}'.format(sum(
                                                (sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 8).mapped('commission')))
                                                if (inv.first_fund_utr_skipped_date and (inv.first_fund_utr_skipped_date &gt;= docs.date_from and inv.first_fund_utr_skipped_date &lt;= docs.date_to))
                                                else 0
                                                for inv in dealer_invoices
                                            ))"/>
                                        </td>

                                        <td style="border:2px solid;">
                                            <t t-set="utr_cutoff_date" t-value="datetime.date(2024, 10, 1)"/>
                                            <span t-esc="'{:,.2f}'.format(sum(
                                                (
                                                    (sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 8).mapped('commission')) -
                                                    (sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 8).mapped('commission')) *
                                                        (0.02 if inv.invoice_date &gt;= utr_cutoff_date else 0.05))
                                                    )
                                                ) if (inv.first_fund_utr_skipped_date and (inv.first_fund_utr_skipped_date &gt;= docs.date_from and inv.first_fund_utr_skipped_date &lt;= docs.date_to))
                                                else 0
                                                for inv in dealer_invoices
                                            ))"/>
                                        </td>

                                        <td style="border:2px solid;"></td>

                                        <td style="border:2px solid;">
                                            <span t-esc="'{:,.2f}'.format(sum(
                                                ((sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 12).mapped('commission')) - inv.deduction))
                                                if (inv.fund_credit_date and (inv.fund_credit_date &gt;= docs.date_from and inv.fund_credit_date &lt;= docs.date_to))
                                                else 0
                                                for inv in dealer_invoices
                                            ))"/>
                                        </td>

                                        <td style="border:2px solid;">
                                            <t t-set="utr_cutoff_date" t-value="datetime.date(2024, 10, 1)"/>
                                            <span t-esc="'{:,.2f}'.format(sum(
                                                (
                                                    ((sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 12).mapped('commission')) - inv.deduction) -
                                                    ((sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 12).mapped('commission')) - inv.deduction) *
                                                        (0.02 if inv.invoice_date &gt;= utr_cutoff_date else 0.05))
                                                    )
                                                ) if (inv.fund_credit_date and (inv.fund_credit_date &gt;= docs.date_from and inv.fund_credit_date &lt;= docs.date_to))
                                                else 0
                                                for inv in dealer_invoices
                                            ))"/>
                                        </td>

                                        <td style="border:2px solid;"></td>

                                        <td style="border:2px solid;">
                                            <span t-esc="'{:,.2f}'.format(sum(sum(inv.commission_history_ids.filtered(lambda h: h.rule_max_days == 45).mapped('deduction')) for inv in dealer_invoices))"/>
                                        </td>
                                        <td style="border:2px solid;">
                                            <span t-esc="'{:,.2f}'.format(sum(sum(inv.commission_history_ids.filtered(lambda h: h.rule_max_days == 60).mapped('deduction')) for inv in dealer_invoices))"/>
                                        </td>
                                        <td style="border:2px solid;">
                                            <span t-esc="'{:,.2f}'.format(sum(sum(inv.commission_history_ids.filtered(lambda h: h.rule_max_days == 120).mapped('deduction')) for inv in dealer_invoices))"/>
                                        </td>

                                        <td style="border:2px solid;">
                                            <span t-esc="'{:,.2f}'.format(sum(inv.deduction for inv in dealer_invoices))"/>
                                        </td>

                                        <td style="border:2px solid;">
                                            <t t-set="utr_cutoff_date" t-value="datetime.date(2024, 10, 1)"/>
                                            <span t-esc="'{:,.2f}'.format(
                                                sum(
                                                    (
                                                        (sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 8).mapped('commission'))) -
                                                        (sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 8).mapped('commission')) *
                                                            (0.02 if inv.invoice_date &gt;= utr_cutoff_date else 0.05))
                                                    )
                                                    if (inv.first_fund_utr_skipped_date and (inv.first_fund_utr_skipped_date &gt;= docs.date_from and inv.first_fund_utr_skipped_date &lt;= docs.date_to))
                                                    else 0
                                                    for inv in dealer_invoices
                                                ) +
                                                sum(
                                                    (
                                                        ((sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 12).mapped('commission')) - inv.deduction)) -
                                                        ((sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 12).mapped('commission')) - inv.deduction) *
                                                            (0.02 if inv.invoice_date &gt;= utr_cutoff_date else 0.05))
                                                    )
                                                    if (inv.fund_credit_date and (inv.fund_credit_date &gt;= docs.date_from and inv.fund_credit_date &lt;= docs.date_to))
                                                    else 0
                                                    for inv in dealer_invoices
                                                )
                                            )"/>
                                        </td>

                                        <td style="border:2px solid;"></td>
                                    </tr>
                                </tfoot>

                            </table>
                        </div>
                    </div>

                    <div class="row mt-4" t-if="not dealer_invoices">
                        <div class="col-12">
                            <p><strong>No invoices found for this dealer in the given duration.</strong></p>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

