                                            <t t-set="final_after" t-value="( (sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 12).mapped('commission')) - inv.deduction) - ((sum(inv.commission_history_ids.filtered(lambda h: h.rule_percentage == 12).mapped('commission')) - inv.deduction) * 0.02) ) if (inv.fund_credit_date and (inv.fund_credit_date &gt;= docs.date_from and inv.fund_credit_date &lt;= docs.date_to)) else 0"/>
                                            <span t-esc="'{:,.2f}'.format(first_after + final_after)"/>
