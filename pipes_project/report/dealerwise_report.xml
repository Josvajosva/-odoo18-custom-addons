<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dealerwise_commission_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="row">
                        <div class="col-12 text-center">
                            <h2><strong>CONSOLIDATED COMMISSION REPORT</strong></h2>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-12 text-align: center;">
                            <p><strong>Report Period:</strong> <span t-esc="docs.date_from"/> to <span t-esc="docs.date_to"/></p>
                        </div>
                    </div>

                    <t t-set="dealer_data" t-value="docs.get_dealer_summary_data()"/>

                    <div class="row mt-4" t-if="dealer_data">
                        <div class="col-12">
                            <table class="table table-bordered" style="width:100%; border-collapse: collapse; border: 2px solid;">
                                <thead>
                                    <tr style="border: 2px solid;">
                                        <th style="border: 2px solid; padding: 8px; text-align: center;">Sr. No.</th>
                                        <th style="border: 2px solid; padding: 8px; text-align: center;">Dealer Name</th>
                                        <th style="border: 2px solid; padding: 8px; text-align: center;">No. of Invoices</th>
                                        <th style="border: 2px solid; padding: 8px; text-align: center;">First Fund Commission</th>
                                        <th style="border: 2px solid; padding: 8px; text-align: center;">Second Fund Commission</th>
                                        <th style="border: 2px solid; padding: 8px; text-align: center;">Total Commission</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <tr t-foreach="dealer_data.values()" t-as="dealer" style="border: 2px solid;">
                                        <td style="border: 2px solid; padding: 8px; text-align: center;">
                                            <span t-esc="dealer_index"/>
                                        </td>
                                        <td style="border: 2px solid; padding: 8px; text-align: center;">
                                            <span t-esc="dealer['dealer'].name"/>
                                        </td>
                                        <td style="border: 2px solid; padding: 8px; text-align: center;">
                                            <span t-esc="dealer.get('invoice_count', 0)"/>
                                        </td>
                                        <td style="border: 2px solid; padding: 8px; text-align: center;">
                                            <span t-esc="'{:,.2f}'.format(dealer.get('total_first_commission', 0.0))"/>
                                        </td>
                                        <td style="border: 2px solid; padding: 8px; text-align: center;">
                                            <span t-esc="'{:,.2f}'.format(dealer.get('total_second_commission', 0.0))"/>
                                        </td>
                                        <td style="border: 2px solid; padding: 8px; text-align: center;">
                                            <span t-esc="'{:,.2f}'.format(dealer.get('total_first_commission', 0.0) + dealer.get('total_second_commission', 0.0))"/>
                                        </td>
                                    </tr>
                                </tbody>

                                <tfoot>
                                    <tr style="border: 2px solid;">
                                        <td style="border: 2px solid; text-align: center;" colspan="2"><strong>GRAND TOTAL</strong></td>
                                        <td style="border: 2px solid; text-align: center;">
                                            <strong>
                                                <span t-esc="sum(dealer.get('invoice_count', 0) for dealer in dealer_data.values())"/>
                                            </strong>
                                        </td>
                                        <td style="border: 2px solid; text-align: center;">
                                            <strong>
                                                <span t-esc="'{:,.2f}'.format(sum(dealer.get('total_first_commission', 0.0) for dealer in dealer_data.values()))"/>
                                            </strong>
                                        </td>
                                        <td style="border: 2px solid; text-align: center;">
                                            <strong>
                                                <span t-esc="'{:,.2f}'.format(sum(dealer.get('total_second_commission', 0.0) for dealer in dealer_data.values()))"/>
                                            </strong>
                                        </td>
                                        <td style="border: 2px solid; text-align: center;">
                                            <strong>
                                                <span t-esc="'{:,.2f}'.format(sum(dealer.get('total_first_commission', 0.0) + dealer.get('total_second_commission', 0.0) for dealer in dealer_data.values()))"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <div class="row mt-4" t-if="not dealer_data">
                        <div class="col-12 text-align: center;">
                            <p><strong>No dealer data found for the selected period.</strong></p>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <record id="dealerwise_commission_report_action" model="ir.actions.report">
        <field name="name">Dealerwise Commission Report</field>
        <field name="model">dealerwise.commission.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pipes_project.dealerwise_commission_report_template</field>
        <field name="print_report_name">'consolidated_commission_report'</field>
        <field name="binding_model_id" ref="model_dealerwise_commission_wizard"/>
        <field name="binding_type">report</field>
    </record>
</odoo>