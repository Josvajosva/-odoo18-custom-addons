<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dealer_commission_wizard" model="ir.ui.view">
        <field name="name">dealer.commission.wizard.form</field>
        <field name="model">dealer.commission.wizard</field>
        <field name="arch" type="xml">
            <form string="Dealer Commission Report">
                <group>
                    <field name="dealer_id" options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button string="Print" type="object" name="action_print_report" class="btn-primary"/>
                    <!-- <button string="View Report" type="object" name="action_view_report" class="btn-secondary"/> -->
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_dealer_commission_wizard_report" model="ir.ui.view">
        <field name="name">dealer.commission.wizard.report.form</field>
        <field name="model">dealer.commission.wizard</field>
        <field name="arch" type="xml">
            <form string="Dealer Commission Report (Detailed)">
                <header>
                    <button name="action_print_report" string="Download PDF" type="object" class="btn-primary"/>
                    <button name="action_export_excel" string="Download Excel" type="object" class="btn-secondary"/>
                </header>
                <group>
                    <field name="dealer_id" readonly="1"/>
                    <field name="date_from" readonly="1"/>
                    <field name="date_to" readonly="1"/>
                </group>

                <separator string="Report"/>

                <field name="line_ids" nolabel="1" readonly="1">
                    <list editable="bottom">
                        <field name="application_id"/>
                        <field name="farmer_name"/>
                        <field name="material_value"/>
                        <field name="commission_amount"/>
                        <field name="first_fund_commission"/>
                        <field name="first_after_tds"/>
                        <field name="first_utr_date"/>
                        <field name="final_fund_commission"/>
                        <field name="final_after_tds"/>
                        <field name="final_utr_date"/>
                        <field name="deduction_45"/>
                        <field name="deduction_60"/>
                        <field name="deduction_120"/>
                        <field name="total_deduction"/>
                        <field name="net_payable"/>
                        <field name="current_status"/>
                    </list>
                </field>

                <group string="Grand Totals">
                    <field name="total_material_value" readonly="1"/>
                    <field name="total_commission_amount" readonly="1"/>
                    <field name="total_first_fund" readonly="1"/>
                    <field name="total_first_after_tds" readonly="1"/>
                    <field name="total_final_fund" readonly="1"/>
                    <field name="total_final_after_tds" readonly="1"/>
                    <field name="total_deduction" readonly="1"/>
                    <field name="total_net_payable" readonly="1"/>
                </group>

            </form>
        </field>
    </record>

    <record id="action_dealer_commission_wizard" model="ir.actions.act_window">
        <field name="name">Dealer Commission Report</field>
        <field name="res_model">dealer.commission.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_dealer_commission_wizard"/>
    </record>

    <menuitem id="menu_dealer_commission_report" name="Dealer Commission Report" 
              parent="menu_invoice_commission_report" 
              action="action_dealer_commission_wizard" 
              sequence="10"/>
</odoo>