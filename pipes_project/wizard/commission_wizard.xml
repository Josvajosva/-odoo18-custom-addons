<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_commission_wizard_form" model="ir.ui.view">
        <field name="name">commission.report.wizard.form</field>
        <field name="model">commission.report.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="app_id" string="Application ID" required="1" options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_download_pdf" string="Generate PDF Report" type="object" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_commission_wizard" model="ir.actions.act_window">
        <field name="name">Commission Report</field>
        <field name="res_model">commission.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_commission_wizard_form"/>
    </record>

    <menuitem id="menu_invoice_commission_report" name="Commission Reports" parent="account.menu_finance_reports"/>

    <!-- <menuitem id="menu_commission_report" name="Invoice Commission Report" 
              parent="menu_invoice_commission_report" 
              action="action_commission_wizard" 
              sequence="10"/> -->
</odoo>