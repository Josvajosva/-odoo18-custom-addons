<?xml version="1.0"?>
<odoo>


        <record id="view_swapping_order_form" model="ir.ui.view">
            <field name="name">customer swapping form</field>
            <field name="model">customer.swaporder</field>
            <field name="arch" type="xml">
                <form string="Customer Swap">
                    <group>
                        <field name="sale_order_id" domain="[('state', '=', 'sale'),('id', 'in', allowed_sale_order_ids)]"/>
                         <field name="allowed_sale_order_ids" invisible="1"/>
                    </group>
                    <footer>
                        <button name="action_swap" type="object" string="confirm" class="btn-primary"/>
                        <button string="cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_swapping_order_new" model="ir.actions.act_window">
            <field name="name">Swapping</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">customer.swaporder</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="mrp_operation_subcontracting.view_swapping_order_form"/>
            <field name="target">new</field>
            <field name="binding_model_id" ref="mrp.model_mrp_production" />
            <field name="binding_view_types">list</field>
        </record>




</odoo>