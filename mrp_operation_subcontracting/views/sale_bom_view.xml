<odoo>
    <record id="view_mrp_production_form_inherit" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.sale</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="domain">[('id', 'in', product_domain)]</attribute>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="before">
                <field name="sale_order_id"/>
                <field name="sale_order_date" readonly="1"/>
                <field name="product_domain" invisible="1"/>
            </xpath>

            <xpath expr="//header/button[@name='button_unbuild']" position="after">
                   <button name="action_open_swap_wizard"
                            type="object"
                            string="Swap Sale Order"
                            class="btn-primary" invisible="1"
                            />
            </xpath>

            <xpath expr="//header/button[@name='button_unbuild']" position="after">
                    <button name="%(mrp_operation_subcontracting.action_swapping_order_new)d"  string="Swap SO" class="oe_highlight"
                         type="action" invisible="is_swap == True or state in ('draft', 'cancel')"/>
            </xpath>

            <xpath expr="//field[@name='user_id']" position="after">
                <field name="is_swap" readonly="1"/>
            </xpath>
        </field>
    </record>
    <record id="view_order_form_inherit_hide_invoice" model="ir.ui.view">
        <field name="name">sale.order.form.hide.create.invoice</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@id='create_invoice']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="customer_preferred_date"/>
            </xpath>
             <xpath expr="//field[@name='customer_preferred_date']" position="after">
                <field name="status_so"/>
            </xpath>

            <div class="oe_button_box" name="button_box">
                <button name="action_view_done_mrp_orders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-industry">
                    <field name="product_done_count" widget="statinfo" string="Done MOs"/>
                </button>
            </div>
        </field>
    </record>



    <record id="mrp_production_search_view_inherit" model="ir.ui.view">
        <field name="name">mrp.production.search.sale.order</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.view_mrp_production_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='product']" position="before">
                <filter string="With Sale Order" name="sale_order_id_filter" domain="[('sale_order_id', '!=', False)]"/>
            </xpath>
            <xpath expr="//search/field[@name='product_id']" position="before">
                <field name="sale_order_id" string="Sale Order Name"/>
            </xpath>
            <xpath expr="//filter[@name='product']" position="before">
                <filter string="Sale Order" name="group_by_sale_order" context="{'group_by': 'sale_order_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
