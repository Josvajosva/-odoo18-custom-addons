    <record id="mrp_production_tree_inherit_status_so" model="ir.ui.view">
        <field name="name">mrp.production.tree.inherit.status.so</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="status_so"/>
            </xpath>
        </field>
    </record>

    <record id="action_sale_order_status" model="ir.actions.act_window">
        <field name="name">Manufacturing Orders</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="mrp.mrp_production_tree_view"/>
        <field name="context">{'group_by': 'sale_order_id'}</field>
    </record>

    <menuitem id="menu_sale_order_status"
              name="Sale Orders Status"
              parent="mrp.menu_mrp_manufacturing"
              action="action_sale_order_status"
              sequence="50"/>



    <record id="action_sale_order_to_invoice" model="ir.actions.act_window">
        <field name="name">Sale Orders Invoicing</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('invoice_status', '=', 'to invoice')]</field>
        <field name="context">{}</field>
    </record>


    <menuitem id="menu_manufacturing_orders"
          name="Sale Order Invoices"
          parent="mrp.menu_mrp_manufacturing"
          action="action_sale_order_to_invoice"
          sequence="60"/>



