<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
         <record id="mail_template_all_so_complete" model="mail.template">
            <field name="name">Sale Order - MOs Completed</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">Your Sale Order {{ object.name }} Manufacturing is Complete</field>
            <field name="email_from">{{ (user.email or 'noreply@example.com')}}</field>
            <field name="email_to"></field>
            <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                    <p>Hello,</p>
                    <p>The manufacturing process for your sale order <strong><t t-out="object.name"/></strong> is now complete.</p>
                    <p>Thank you for your business!</p>
                    <p>Best regards,<br/>Your Company</p>
            </div>
            </field>

         </record>

