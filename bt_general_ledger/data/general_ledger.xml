<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="gl_voucher_no" model="account.report.column">
        <field name="name">Voucher No</field>
        <field name="expression_label">voucher_no</field>
        <field name="figure_type">string</field>
        <field name="sequence">150</field>
        <field name="report_id" ref="account_reports.general_ledger_report"/>
    </record>

    <record id="gl_voucher_type" model="account.report.column">
        <field name="name">Voucher Type</field>
